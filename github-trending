#!/usr/bin/env python3

from cli import cli_arg_parse
from utils import get_repos

# parse CLI arguments
args = cli_arg_parse()
duration = args.duration
limit = args.limit

repos = get_repos(duration, limit) # list of dicts

for repo in repos:
    print(f"{repo['stargazers_count']} stars: {repo['name']}")
    print(repo['html_url'])
    print(repo['description'])
    print("-----------")